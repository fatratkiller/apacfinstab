# Virtuals ACP Configuration
# Copy this to .env and fill in values

# Wallet private key (for signing transactions)
# ⚠️ Use a dedicated wallet for ACP, not your main wallet!
WALLET_PRIVATE_KEY=0x...

# Agent wallet address (your registered agent's address)
AGENT_WALLET_ADDRESS=0x...

# Session Entity Key ID (obtained during agent registration)
SESSION_ENTITY_KEY_ID=

# ACP Environment (sandbox or mainnet)
ACP_ENV=sandbox

# APAC FINSTAB MCP API endpoint
MCP_API_BASE=https://apacfinstab.kyleleo2018.workers.dev
